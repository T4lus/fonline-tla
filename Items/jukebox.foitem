[ProtoItem]
$Name = jukebox

Weight = 500000
IsShowAnim = True
Material = 1
IsCanUse = True
Type = Misc
IsLight = True
PicMap = art/items/jbl02.FRM
LightDistance = 8
LightIntensity = 50
LightColor = 0xff000000
Corner = West
